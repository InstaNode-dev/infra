{
  "name": "instant-api — audit feed (W7/W8/W9 kinds)",
  "description": "Aggregate counter board for the ~25 new audit kinds shipped in waves W4-B3, W5-B-api, W7-A through W7-G, W8 (PATCH /team), and W9-C1 (storage IAM). One billboard tile per kind plus tier-faceted breakdowns for kinds that vary by tier (subscription.*, backup.*, deploy.*). Source: Log records emitted to NR via the audit middleware where audit_kind is the canonical tag. Queries are intentionally tag-driven (WHERE audit_kind = '<kind>') so the dashboard works the moment a new kind starts emitting, without redeploying the dashboard.",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Wave 9 audit counts",
      "description": "Hits last 24h per audit kind. Use FACET tier on the tile to drill into per-plan usage.",
      "widgets": [
        {
          "title": "team.updated (hits 24h)",
          "layout": { "column": 1, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "SELECT count(*) FROM Log WHERE service = 'api' AND audit_kind = 'team.updated' SINCE 24 hours ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
