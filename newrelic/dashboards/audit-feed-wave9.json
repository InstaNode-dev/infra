    {
      "name": "Tier breakdowns",
      "description": "Per-tier facet for kinds whose business meaning depends on plan tier. Anonymous floods are noise; pro/team activity is signal.",
      "widgets": [
        {
          "title": "subscription.* by tier (last 7d)",
          "layout": { "column": 1, "row": 1, "width": 6, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "SELECT count(*) FROM Log WHERE service = 'api' AND audit_kind LIKE 'subscription.%' FACET audit_kind, tier SINCE 7 days ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "backup.requested + restore.requested by tier (last 7d)",
          "layout": { "column": 7, "row": 1, "width": 6, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "SELECT count(*) FROM Log WHERE service = 'api' AND audit_kind IN ('backup.requested', 'restore.requested') FACET audit_kind, tier SINCE 7 days ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "deploy.failed by team (rolling 1h, extends api-overview)",
          "layout": { "column": 1, "row": 4, "width": 12, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "SELECT count(*) FROM Log WHERE service = 'api' AND audit_kind = 'deploy.failed' FACET team_id, tier SINCE 1 hour ago LIMIT 30"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "vault.read + vault.write timeseries (vault traffic shape)",
          "layout": { "column": 1, "row": 7, "width": 12, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "SELECT count(*) FROM Log WHERE service = 'api' AND audit_kind IN ('vault.read', 'vault.write') FACET audit_kind TIMESERIES AUTO"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
